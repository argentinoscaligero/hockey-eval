# ── Base de datos ──────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hockey_eval
DB_USER=hockey_app
DB_PASSWORD=CAMBIAR_PASSWORD_SEGURA

# ── Servidor ───────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── Seguridad ──────────────────────────────────────────
# Generá con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIAR_POR_STRING_ALEATORIO_LARGO

# ── Admin ──────────────────────────────────────────────
# Hash bcrypt de la contraseña admin. Generá con:
# node -e "const b=require('bcryptjs');b.hash('tuPassword',12).then(console.log)"
ADMIN_PASSWORD_HASH=$2a$12$HASH_GENERADO_AQUI

# ── CORS ───────────────────────────────────────────────
FRONTEND_URL=https://tests.miclub.com.ar
